# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Relevix environment variable template
#
# USAGE:
#   cp .env.example .env
#   Fill in all values marked [REQUIRED] before running.
#
# RULES:
#   1. Never commit .env to version control.
#   2. In production, inject secrets via Podman secrets or Vault / AWS SSM:
#        podman secret create jwt_secret <(echo -n "supersecret")
#   3. In CI, use your provider's encrypted secret store.
#   4. Values with defaults can be left as-is for local development.
#
# STRATEGY:
#   - All config is sourced from environment variables (12-factor app).
#   - Each service has its own required set; @relevix/config validates on startup.
#   - Secrets (passwords, JWT key) have NO defaults — they must always be set.
# ─────────────────────────────────────────────────────────────────────────────

# ── Global ────────────────────────────────────────────────────────────────────
NODE_ENV=development                    # development | test | production
LOG_LEVEL=debug                         # trace | debug | info | warn | error | fatal
SERVICE_VERSION=0.0.1

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=           # e.g. http://otel-collector:4317

# ── API Gateway ───────────────────────────────────────────────────────────────
API_GATEWAY_PORT=3000
JWT_SECRET=                            # [REQUIRED] min 32 chars — use: openssl rand -hex 32
JWT_EXPIRES_IN=15m
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

RULE_ENGINE_URL=http://localhost:8080
INGESTION_URL=http://localhost:4000

# ── Intelligence API (api-gateway) ────────────────────────────────────────────
# How long ranked insights and root-cause results are cached in Redis.
# Set just under the Go rule-engine's PRECOMPUTE_TICK_INTERVAL (default 30s).
INTELLIGENCE_CACHE_TTL_SECONDS=25
# Max requests per minute to /v1/insights, /v1/root-cause, /v1/logs per client.
INTELLIGENCE_RATE_LIMIT_MAX=30

# ── Rule Engine ───────────────────────────────────────────────────────────────
RULE_ENGINE_PORT=8080

# ── Ingestion ─────────────────────────────────────────────────────────────────
INGESTION_PORT=4000
ENVIRONMENT=development

# Pipeline tuning (defaults target 10k logs/sec on 4-core host)
INTAKE_BUFFER_SIZE=50000        # bounded channel cap between intake and workers
WORKER_COUNT=32                 # normalize goroutines (tune to CPU cores * 2)
BATCH_SIZE=250                  # max logs per output batch
BATCH_FLUSH_INTERVAL=200ms      # max latency before partial batch is flushed
OUTPUT_BUFFER_SIZE=10000        # bounded channel between batcher and output router

# Retry / DLQ
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY=500ms
RETRY_BUFFER_SIZE=5000

# Kafka input / output / DLQ topics
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=relevix-ingestion
KAFKA_GROUP_ID=relevix-ingestion-group
KAFKA_TOPIC_INPUT=relevix.logs.raw
KAFKA_TOPIC_OUTPUT=relevix.logs.normalized
KAFKA_TOPIC_DLQ=relevix.logs.dlq
KAFKA_MAX_BYTES=10485760        # 10 MiB
KAFKA_COMMIT_INTERVAL=1s

# Observability
METRICS_PORT=9090               # Prometheus /metrics for ingestion (0 to disable)

# ── Signal-Processor ──────────────────────────────────────────────────────────
KAFKA_TOPIC_SIGNALS=relevix.signals
WINDOW_SIZE=60s                 # observation look-back window
TICK_INTERVAL=10s               # how often window snapshots are emitted
RING_CAPACITY=16384             # per-dimension ring buffer capacity
MAX_DIMENSIONS=10000            # max (tenant, service, env) keys tracked
OBS_CHAN_SIZE=50000             # intake observation channel depth
SNAPSHOT_CHAN_SIZE=2000         # snapshot channel depth
SIGNAL_CHAN_SIZE=5000           # output signal channel depth
SIGNAL_PROCESSOR_PORT=8082      # HTTP query API port (host)
SIGNAL_PROCESSOR_METRICS_PORT=9092  # Prometheus metrics port (host)

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=relevix
POSTGRES_PASSWORD=                     # [REQUIRED]
POSTGRES_DB=relevix_dev
DATABASE_URL=postgres://relevix:@localhost:5432/relevix_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=                        # [REQUIRED] in production
REDIS_URL=redis://:@localhost:6379

# ── Kafka cluster ID (KRaft mode) ─────────────────────────────────────────────
KAFKA_CLUSTER_ID=                      # [REQUIRED] generate with: kafka-storage random-uuid
