# ─────────────────────────────────────────────────────────────────────────────
# API Gateway — environment variable template
#
# Copy to .env and fill in values before starting the gateway:
#   cp apps/api-gateway/.env.example apps/api-gateway/.env
#
# .env is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Service identity ──────────────────────────────────────────────────────────
NODE_ENV=development
SERVICE_NAME=api-gateway
SERVICE_VERSION=0.0.1
LOG_LEVEL=info

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters.
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=15m

# ── Downstream services ───────────────────────────────────────────────────────
RULE_ENGINE_URL=http://localhost:8080
INGESTION_URL=http://localhost:4000

# ── Redis ─────────────────────────────────────────────────────────────────────
# Started by podman-compose.dev.yml on port 6379
REDIS_URL=redis://localhost:6379

# ── Postgres ──────────────────────────────────────────────────────────────────
# Started by podman-compose.dev.yml (user: relevix / pw: devpassword / db: relevix_dev)
DATABASE_URL=postgresql://relevix:devpassword@localhost:5432/relevix_dev

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# ── Intelligence cache ────────────────────────────────────────────────────────
INTELLIGENCE_CACHE_TTL_SECONDS=25
INTELLIGENCE_RATE_LIMIT_MAX=30

# ── Elasticsearch (optional — search disabled if unreachable) ─────────────────
ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_API_KEY=           # leave blank for unauthenticated local ES
ELASTICSEARCH_INDEX_PREFIX=relevix-insights
ELASTICSEARCH_TIMEOUT_MS=80
SEARCH_CACHE_TTL_SECONDS=10

# ── AI Narrator (optional — deterministic fallback used if unset) ─────────────
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=150
AI_NARRATOR_TIMEOUT_MS=3000
AI_NARRATOR_ENABLED=true

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
