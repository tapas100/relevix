{
  "name": "@relevix/api-gateway",
  "version": "0.0.1",
  "private": true,
  "description": "Relevix API Gateway — public-facing REST + WebSocket entrypoint",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch --env-file=.env src/main.ts",
    "start": "node --env-file=.env dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@relevix/config": "workspace:*",
    "@relevix/errors": "workspace:*",
    "@relevix/logger": "workspace:*",
    "@relevix/types": "workspace:*",
    "fastify": "^4.28.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/jwt": "^8.0.1",
    "fastify-plugin": "^4.5.1",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8",
    "ioredis": "^5.4.1",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
