{
  "name": "@relevix/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Relevix CLI — analyze, inspect, and compare infrastructure insights from the terminal",
  "type": "module",
  "bin": {
    "relevix": "./dist/apps/cli/src/index.js"
  },
  "scripts": {
    "build":     "tsc --project tsconfig.json",
    "dev":       "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "link:local": "pnpm build && npm link"
  },
  "dependencies": {
    "@relevix/types":  "workspace:*",
    "chalk":           "^5.3.0",
    "cli-table3":      "^0.6.5",
    "commander":       "^12.1.0",
    "ora":             "^8.0.1",
    "conf":            "^13.0.0"
  },
  "devDependencies": {
    "@types/node":  "^20.14.0",
    "tsx":          "^4.16.0",
    "typescript":   "^5.5.2"
  }
}
